---
import {
  getCollection,
  render,
  type CollectionEntry,
} from "astro:content";
import Base from "../../layouts/Base.astro";
import StatusBadge from "../../components/StatusBadge.astro";

export async function getStaticPaths() {
  const apps = await getCollection("apps");
  return apps.map((app: CollectionEntry<"apps">) => ({
    params: { slug: app.id },
    props: { app },
  }));
}

const { app } = Astro.props as { app: CollectionEntry<"apps"> };
const { Content } = await render(app);
const { name, url, status, category, description, year, owner, platform } =
  app.data;
---

<Base title={`${name} — Armalo product catalogue`} description={description}>
  <article class="mx-auto max-w-3xl px-6 pt-16 pb-12">
    <a href="/#work" class="text-sm text-ink-soft link-quiet hover:text-ink">
      ← Back to catalogue
    </a>

    <div class="mt-10 flex flex-wrap items-start justify-between gap-4">
      <div>
        <p class="text-2xs font-medium uppercase tracking-[0.18em] text-accent">
          {category}
        </p>
        <h1 class="mt-3 text-4xl text-ink">{name}</h1>
      </div>
      <StatusBadge status={status} />
    </div>

    <p class="mt-6 max-w-2xl text-xl leading-relaxed text-ink-soft">
      {description}
    </p>

    <div class="mt-10 grid gap-6 border-y border-line py-6 text-sm sm:grid-cols-3">
      {owner && (
        <div>
          <p class="text-2xs uppercase tracking-wide text-ink-faint">Owner</p>
          <p class="mt-1 text-ink">{owner}</p>
        </div>
      )}
      {platform && (
        <div>
          <p class="text-2xs uppercase tracking-wide text-ink-faint">Surface</p>
          <p class="mt-1 text-ink">{platform}</p>
        </div>
      )}
      <div>
        <p class="text-2xs uppercase tracking-wide text-ink-faint">Started</p>
        <p class="mt-1 text-ink">{year}</p>
      </div>
    </div>

    <div class="prose mt-10 max-w-2xl text-ink-soft">
      <Content />
    </div>

    <div class="mt-12 flex flex-wrap items-center gap-4">
      {url && status !== "planned" && (
        <a
          href={url}
          target="_blank"
          rel="noopener noreferrer"
          class="rounded-md bg-ink px-4 py-2 text-sm font-medium text-paper link-quiet hover:bg-accent"
        >
          Open product
        </a>
      )}
      {name === "Girl Math" && (
        <a
          href="/agents/girl-math.md"
          class="rounded-md border border-line px-4 py-2 text-sm text-ink link-quiet hover:border-accent"
        >
          Hermes invocation contract
        </a>
      )}
    </div>
  </article>
</Base>
