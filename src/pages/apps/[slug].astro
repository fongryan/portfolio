---
import { getCollection, render, type CollectionEntry } from "astro:content";
import Base from "../../layouts/Base.astro";
import StatusBadge from "../../components/StatusBadge.astro";
import {
  accessLabels,
  deliveryLabels,
  flywheelDescriptions,
  flywheelLabels,
  offerLabels,
  proofLabels,
  type DeliveryMode,
  type OfferMode,
} from "../../lib/apps";

export async function getStaticPaths() {
  const apps = await getCollection("apps");
  return apps.map((app: CollectionEntry<"apps">) => ({
    params: { slug: app.id },
    props: { app },
  }));
}

const { app } = Astro.props as { app: CollectionEntry<"apps"> };
const { Content } = await render(app);
const {
  name,
  url,
  status,
  access,
  proof,
  flywheel,
  lastVerified,
  category,
  description,
  year,
  owner,
  platform,
  ctaLabel,
  highlights,
  audiences,
  deliveryModes,
  offerModes,
  salesPosition,
} = app.data;
---

<Base title={`${name} — Armalo product catalogue`} description={description}>
  <article class="mx-auto max-w-3xl px-6 pt-16 pb-12">
    <a href="/#work" class="text-sm text-ink-soft link-quiet hover:text-ink"
      >← Back to catalogue</a
    >
    <div class="mt-10 flex flex-wrap items-start justify-between gap-4">
      <div>
        <p class="text-2xs font-medium uppercase tracking-[0.18em] text-accent">
          {category}
        </p><h1 class="mt-3 text-4xl text-ink">{name}</h1>
      </div>
      <StatusBadge status={status} />
    </div>
    <p class="mt-6 max-w-2xl text-xl leading-relaxed text-ink-soft">
      {description}
    </p>
    <p class="mt-4 max-w-2xl text-base leading-relaxed text-ink-soft">
      {salesPosition}
    </p>

    <div
      class="mt-10 grid gap-6 border-y border-line py-6 text-sm sm:grid-cols-3"
    >
      <div>
        <p class="text-2xs uppercase tracking-wide text-ink-faint">Access</p><p
          class="mt-1 text-ink"
        >
          {accessLabels[access]}
        </p>
      </div>
      <div>
        <p class="text-2xs uppercase tracking-wide text-ink-faint">Proof</p><p
          class="mt-1 text-ink"
        >
          {proofLabels[proof]}
        </p>
      </div>
      <div>
        <p class="text-2xs uppercase tracking-wide text-ink-faint">
          Verified
        </p><p class="mt-1 text-ink">
          <time datetime={lastVerified}>{lastVerified}</time>
        </p>
      </div>
      <div>
        <p class="text-2xs uppercase tracking-wide text-ink-faint">
          Flywheel stage
        </p><p class="mt-1 text-ink" title={flywheelDescriptions[flywheel]}>
          <a href="/flywheel" class="link-quiet hover:text-accent"
            >{flywheelLabels[flywheel]}</a
          >
        </p>
      </div>
      {
        owner && (
          <div>
            <>
              <p class="text-2xs uppercase tracking-wide text-ink-faint">
                Owner
              </p>
              <p class="mt-1 text-ink">{owner}</p>
            </>
          </div>
        )
      }
      {
        platform && (
          <div>
            <>
              <p class="text-2xs uppercase tracking-wide text-ink-faint">
                Surface
              </p>
              <p class="mt-1 text-ink">{platform}</p>
            </>
          </div>
        )
      }
      <div>
        <p class="text-2xs uppercase tracking-wide text-ink-faint">Started</p><p
          class="mt-1 text-ink"
        >
          {year}
        </p>
      </div>
    </div>

    <div
      class="mt-8 grid gap-6 border-b border-line pb-8 text-sm sm:grid-cols-3"
    >
      <div>
        <p class="text-2xs uppercase tracking-wide text-ink-faint">
          Best for
        </p><p class="mt-1 text-ink">{audiences.join(" · ")}</p>
      </div>
      <div>
        <p class="text-2xs uppercase tracking-wide text-ink-faint">
          Delivery modes
        </p><p class="mt-1 text-ink">
          {
            deliveryModes
              .map((mode: DeliveryMode) => deliveryLabels[mode])
              .join(" · ")
          }
        </p>
      </div>
      <div>
        <p class="text-2xs uppercase tracking-wide text-ink-faint">
          Offer shapes
        </p><p class="mt-1 text-ink">
          {offerModes.map((mode: OfferMode) => offerLabels[mode]).join(" · ")}
        </p>
      </div>
    </div>

    <div class="prose mt-10 max-w-2xl text-ink-soft"><Content /></div>
    <section class="mt-10 max-w-2xl" aria-labelledby="highlights-heading">
      <h2 id="highlights-heading" class="text-xl text-ink">What you can do</h2>
      <ul class="mt-4 space-y-2 text-ink-soft">
        {
          highlights.map((highlight: string) => (
            <li class="flex gap-3">
              <>
                <span class="text-accent" aria-hidden="true">
                  —
                </span>
                <span>{highlight}</span>
              </>
            </li>
          ))
        }
      </ul>
    </section>
    <div class="mt-12 flex flex-wrap items-center gap-4">
      {
        url && access !== "unavailable" && (
          <a
            href={url}
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-md bg-ink px-4 py-2 text-sm font-medium text-paper link-quiet hover:bg-accent"
          >
            {ctaLabel}
          </a>
        )
      }
    </div>
  </article>
</Base>
