---
import Base from "../layouts/Base.astro";
import AppCard from "../components/AppCard.astro";
import StatusBadge from "../components/StatusBadge.astro";
import AnnotationDashboard from "../components/AnnotationDashboard.astro";
import {
  countAvailable,
  flywheelLabels,
  flywheelStages,
  getApps,
  hasRealApps,
} from "../lib/apps";
import { buildCatalogueGroups } from "../lib/catalogue-groups";
import {
  businessDemandProducts,
  consumerLabScopeLabel,
  consumerLabSlugs,
} from "../lib/demand-catalogue";
import { productAtlas } from "../lib/product-atlas";

const apps = await getApps();
const availableCount = countAvailable(apps);
const total = apps.length;
const hasReal = hasRealApps(apps);
const catalogueSummary = `${total} ${total === 1 ? "product" : "products"}${hasReal ? ` · ${availableCount} available` : " · coming soon"}`;
const groups = buildCatalogueGroups(apps);
const appsBySlug = new Map(apps.map((app) => [app.id, app]));
const requireApps = (slugs: string[], label: string) =>
  slugs.map((slug) => {
    const app = appsBySlug.get(slug);
    if (!app)
      throw new Error(`${label} references missing catalogue product: ${slug}`);
    return app;
  });
const liveApps = apps.filter(
  (app) => app.data.status === "live" || app.data.status === "beta",
);
const commercialShortlist = apps
  .filter((app) => app.data.commercialPriority !== undefined)
  .sort(
    (a, b) =>
      (a.data.commercialPriority ?? 99) - (b.data.commercialPriority ?? 99),
  );
const rankedDemandApps = businessDemandProducts.map((product) => ({
  product,
  app: requireApps([product.slug], "Demand ranking")[0],
}));
const consumerLabApps = requireApps(consumerLabSlugs, "Consumer lab");
const atlasPreview = productAtlas.slice(0, 8);
---

<Base>
  <section class="hero-wrap">
    <div class="hero mx-auto max-w-6xl px-6 py-8 sm:px-10 sm:py-12">
      <div class="hero__copy">
        <p class="eyebrow eyebrow--light">Ryan Fong / Armalo studio</p>
        <h1>Useful AI,<br /><em>made tangible.</em></h1>
        <p class="hero__lede">
          I build small, sharp products that turn messy work into a place you
          can act. One live workspace. A growing shelf of focused tools. No
          theatre.
        </p>
        <div class="hero__actions">
          <a class="button button--bright" href="https://app.armalo.ai"
            >Open Armalo App <span aria-hidden="true">↗</span></a
          >
          <a class="hero__text-link" href="#live"
            >See the work <span aria-hidden="true">↓</span></a
          >
        </div>
      </div>
      <div
        class="hero__signal"
        aria-label="Portfolio signal: 41 products, 2 available, one operating system"
      >
        <div class="signal-ring signal-ring--outer"></div>
        <div class="signal-ring signal-ring--inner"></div>
        <div class="signal-core"><span>ARMALO</span><strong>01</strong></div>
        <div class="signal-label signal-label--top">{catalogueSummary}</div>
        <div class="signal-label signal-label--right">
          build · launch · compound
        </div>
        <div class="signal-label signal-label--bottom">a public work log</div>
      </div>
    </div>
    <div class="hero__rail mx-auto max-w-6xl px-6 sm:px-10">
      {
        flywheelStages.map((stage, index) => (
          <span>
            <b>{String(index + 1).padStart(2, "0")}</b> {flywheelLabels[stage]}
          </span>
        ))
      }
    </div>
  </section>

  <AnnotationDashboard />

  <section class="intro-grid mx-auto max-w-6xl px-6 py-20 sm:px-10 sm:py-28">
    <div>
      <p class="eyebrow">The point of view</p>
      <h2>Make the useful<br />part <em>obvious.</em></h2>
    </div>
    <div class="intro-grid__body">
      <p class="lead-copy">
        Most AI products stop at a clever answer. Armalo is interested in what
        happens next: the decision, the handoff, the work that compounds.
      </p>
      <p>
        These are public records of that build. The live products are live. The
        planned products are labelled planned. The catalogue is allowed to be
        ambitious without pretending it is finished.
      </p>
      <a class="arrow-link" href="/flywheel"
        >See how the loop works <span aria-hidden="true">↗</span></a
      >
    </div>
  </section>

  <section
    id="live"
    class="work-section mx-auto max-w-6xl px-6 pb-20 sm:px-10 sm:pb-32"
  >
    <div class="section-heading">
      <div>
        <p class="eyebrow">Live / in the world</p><h2>Two doors in.</h2>
      </div>
      <p>
        Small experiments with real users, real edges, and a clear next step.
      </p>
    </div>
    <div class="live-grid">
      {
        liveApps.map((app, index) => (
          <a
            class:list={[
              "live-card",
              index === 0 ? "live-card--dark" : "live-card--light",
            ]}
            href={app.data.url}
          >
            <div class="live-card__top">
              <>
                <span class="card-index">0{index + 1}</span>
                <StatusBadge status={app.data.status} />
              </>
            </div>
            <div class="live-card__body">
              <>
                <p class="card-kicker">{app.data.category}</p>
                <h3>{app.data.name}</h3>
                <p>{app.data.description}</p>
              </>
            </div>
            <div class="live-card__foot">
              <>
                <span>{app.data.ctaLabel}</span>
                <span aria-hidden="true">↗</span>
              </>
            </div>
          </a>
        ))
      }
    </div>
  </section>

  <section class="shortlist-band">
    <div
      class="mx-auto grid max-w-6xl gap-10 px-6 py-20 sm:px-10 md:grid-cols-[0.8fr_1.2fr] md:py-28"
    >
      <div>
        <p class="eyebrow eyebrow--light">Internal validation candidates</p><h2>
          Problems worth<br /><em>staying with.</em>
        </h2><p class="band-copy">
          Studio hypotheses for the next releases, not the market-evidence
          ranking. These are not customer claims.
        </p>
      </div>
      <ol class="shortlist">
        {
          commercialShortlist.slice(0, 6).map((app, index) => (
            <li>
              <a href={`/apps/${app.id}`}>
                <>
                  <span class="shortlist__number">
                    {String(index + 1).padStart(2, "0")}
                  </span>
                  <span>
                    <>
                      <strong>{app.data.name}</strong>
                      <small>
                        {app.data.buyerHypothesis?.replace(
                          /^Armalo hypothesis:\s*/,
                          "",
                        )}
                      </small>
                    </>
                  </span>
                  <span class="shortlist__arrow" aria-hidden="true">
                    ↗
                  </span>
                </>
              </a>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <section
    id="demand"
    class="demand-section mx-auto max-w-6xl px-6 py-20 sm:px-10 sm:py-28"
  >
    <div class="section-heading">
      <div>
        <p class="eyebrow">Market signal</p><h2>
          What people already<br />pay to fix.
        </h2>
      </div><div>
        <p>
          Ten product families ranked by urgency, repeatability, time to value,
          build feasibility, safety, and proofability.
        </p><a class="arrow-link" href="/research/demand-backed-ai-catalogue/"
          >Read the research <span aria-hidden="true">↗</span></a
        >
      </div>
    </div>
    <ol class="demand-list">
      {
        rankedDemandApps.map(({ product, app }) => (
          <li>
            <>
              <span class="demand-list__rank">
                {String(product.rank).padStart(2, "0")}
              </span>
              <AppCard app={app} compact />
            </>
          </li>
        ))
      }
    </ol>
    <aside id="consumer-lab" class="consumer-lab" aria-label="Consumer lab">
      <div>
        <p class="eyebrow">Consumer lab</p><p>{consumerLabScopeLabel}</p>
      </div><div class="consumer-lab__links">
        {
          consumerLabApps.map((app) => (
            <a href={`/apps/${app.id}`}>
              {app.data.name} <span aria-hidden="true">↗</span>
            </a>
          ))
        }
      </div>
    </aside>
  </section>

  <section
    id="work"
    class="catalogue-section mx-auto max-w-6xl px-6 pb-20 sm:px-10 sm:pb-28"
  >
    <div class="section-heading">
      <div>
        <p class="eyebrow">The full catalogue</p><h2>
          There is more<br />under the hood.
        </h2>
      </div><div>
        <p>
          One canonical record for every product family. Browse by category, or
          jump straight to the atlas.
        </p><a class="arrow-link" href="/marketing"
          >Open the campaign library <span aria-hidden="true">↗</span></a
        >
      </div>
    </div>
    <nav class="category-nav" aria-label="Catalogue categories">
      {groups.map((group) => <a href={`#${group.id}`}>{group.label}</a>)}
    </nav>
    <div class="catalogue-groups">
      {
        groups.map((group) => (
          <section id={group.id} aria-labelledby={`${group.id}-heading`}>
            <>
              <div class="catalogue-group__header">
                <>
                  <h3 id={`${group.id}-heading`}>{group.label}</h3>
                  <span>
                    {group.apps.length}{" "}
                    {group.apps.length === 1 ? "offer" : "offers"}
                  </span>
                </>
              </div>
              <ul class="catalogue-group__list">
                {group.apps.map((app) => (
                  <li>
                    <a href={`/apps/${app.id}`} class="catalogue-product">
                      <span class="catalogue-product__name">
                        {app.data.name}
                      </span>
                      <StatusBadge status={app.data.status} compact />
                    </a>
                  </li>
                ))}
              </ul>
            </>
          </section>
        ))
      }
    </div>
  </section>

  <section class="atlas-band">
    <div
      class="mx-auto grid max-w-6xl gap-10 px-6 py-20 sm:px-10 sm:py-28 md:grid-cols-[0.8fr_1.2fr]"
    >
      <div>
        <p class="eyebrow">The buildable universe</p><h2>
          {productAtlas.length} ways to make work <em>lighter.</em>
        </h2><p class="band-copy band-copy--ink">
          A product atlas spanning revenue, service, marketing, finance, people,
          healthcare, legal, commerce, software, education, and agent
          infrastructure.
        </p><a class="arrow-link" href="/research/ai-product-atlas/"
          >Browse the atlas <span aria-hidden="true">↗</span></a
        >
      </div><ul class="atlas-list">
        {
          atlasPreview.map((product, index) => (
            <li>
              <>
                <span>{String(index + 1).padStart(2, "0")}</span>
                <a href={`/research/ai-product-atlas/#${product.slug}`}>
                  {product.name}
                </a>
                <small>{product.category}</small>
              </>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section
    id="about"
    class="about-section mx-auto max-w-6xl px-6 py-20 sm:px-10 sm:py-28"
  >
    <p class="eyebrow">About the build</p><div class="about-grid">
      <h2>One catalogue.<br />Many ways <em>forward.</em></h2><div>
        <p class="lead-copy">
          Armalo is the thread between product packaging, agent tuning, and
          implementation discipline.
        </p><p>
          The public shelf is deliberately honest. It shows what exists, what is
          being tested, and what is still a strong idea waiting for its first
          proof.
        </p><p class="about-links">
          <a class="arrow-link" href="https://github.com/fongryan"
            >GitHub <span aria-hidden="true">↗</span></a
          ><a class="arrow-link" href="/agents/portfolio.md"
            >Machine-readable catalogue <span aria-hidden="true">↗</span></a
          >
        </p>
      </div>
    </div>
  </section>
</Base>
