---
/*
 * Homepage. Hero + the product grid driven entirely by the `apps` content
 * collection. Copy is specific and quiet; layout is left-aligned and roomy.
 */
import Base from "../layouts/Base.astro";
import AppCard from "../components/AppCard.astro";
import {
  getApps,
  countAvailable,
  hasRealApps,
  flywheelStages,
  flywheelLabels,
} from "../lib/apps";

const apps = await getApps();
const availableCount = countAvailable(apps);
const total = apps.length;
const hasReal = hasRealApps(apps);
const catalogueSummary = `${total} ${total === 1 ? "product" : "products"}${
  hasReal ? ` · ${availableCount} available` : " · coming soon"
}`;
---

<Base>
  <section class="mx-auto max-w-3xl px-6 pt-20 pb-12">
    <p class="text-2xs font-medium uppercase tracking-[0.18em] text-accent">
      Portfolio
    </p>
    <h1 class="mt-4 max-w-2xl text-4xl text-ink">
      Focused products, run as one flywheel.
    </h1>
    <p class="mt-5 max-w-xl text-lg text-ink-soft">
      I’m Ryan Fong. My wife and I build small AI products with Armalo, launch
      each one on its own subdomain, and reinvest what a product earns into the
      next. This catalogue is the strategy board.
    </p>
    <p class="mt-6 text-sm text-ink-faint">
      {catalogueSummary}
    </p>
    <p
      class="mt-8 flex flex-wrap items-baseline gap-x-2 gap-y-1 text-2xs uppercase tracking-wide text-ink-faint"
    >
      {
        flywheelStages.map((stage, index) => (
          <>
            {index > 0 && <span aria-hidden="true">→</span>}
            <span>{flywheelLabels[stage]}</span>
          </>
        ))
      }
      <span aria-hidden="true">↺</span>
      <a href="/flywheel" class="link-quiet text-accent hover:text-ink">
        The loop
      </a>
    </p>
  </section>

  <section id="work" class="mx-auto max-w-3xl px-6 pb-8">
    <div class="mb-5 flex items-baseline justify-between">
      <h2 class="text-xl text-ink">Work</h2>
      <span class="text-2xs uppercase tracking-wide text-ink-faint"
        >Products</span
      >
    </div>

    {
      apps.length === 0 ? (
        <p class="text-ink-soft">
          The first product is being prepared for the catalogue.
        </p>
      ) : (
        <ul class="grid auto-rows-fr grid-cols-1 gap-4 sm:grid-cols-2">
          {apps.map((app) => (
            <li>
              <AppCard app={app} />
            </li>
          ))}
        </ul>
      )
    }
  </section>

  <section id="about" class="mx-auto max-w-3xl px-6 pt-16">
    <h2 class="text-xl text-ink">About</h2>
    <div class="mt-4 space-y-4 text-ink-soft">
      <p>
        This catalogue publishes focused experiments once there is a real
        visitor-facing surface to explore. Each entry separates maturity,
        access, proof, and its <a
          href="/flywheel"
          class="link-quiet text-ink hover:text-accent">flywheel stage</a
        > so an early beta is not mistaken for a finished, earning service.
      </p>
      <p>
        Armalo is the thread between them: a two-person studio building
        practical AI products around a specific decision or workflow, with
        claims kept as concrete as the evidence behind them.
      </p>
    </div>
  </section>
</Base>
