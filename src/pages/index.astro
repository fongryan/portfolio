---
import Base from "../layouts/Base.astro";
import AppCard from "../components/AppCard.astro";
import {
  countAvailable,
  flywheelLabels,
  flywheelStages,
  getApps,
  hasRealApps,
} from "../lib/apps";

const apps = await getApps();
const availableCount = countAvailable(apps);
const total = apps.length;
const hasReal = hasRealApps(apps);
const catalogueSummary = `${total} ${total === 1 ? "product" : "products"}${hasReal ? ` · ${availableCount} available` : " · coming soon"}`;
const groups = [
  "Customer service",
  "Personal finance",
  "Learning",
  "Legal workflows",
  "Revenue operations",
  "Business operations",
  "Capital intelligence",
  "Sports intelligence",
  "Agency infrastructure",
];
---

<Base>
  <section class="mx-auto max-w-5xl px-6 pt-20 pb-12">
    <p class="text-2xs font-medium uppercase tracking-[0.18em] text-accent">
      Portfolio
    </p>
    <h1 class="mt-4 max-w-2xl text-4xl text-ink">
      A catalogue of AI products your team can actually sell.
    </h1>
    <p class="mt-5 max-w-xl text-lg text-ink-soft">
      Armalo builds and tunes practical AI assistants for businesses, agencies,
      and teams. This is the product shelf: pick the job, choose the audience,
      shape the offer, then route the build through the flywheel and a separate
      delivery lane.
    </p>
    <p class="mt-6 text-sm text-ink-faint">{catalogueSummary}</p>
    <p
      class="mt-8 flex flex-wrap items-baseline gap-x-2 gap-y-1 text-2xs uppercase tracking-wide text-ink-faint"
    >
      {
        flywheelStages.map((stage, index) => (
          <Fragment>
            {index > 0 && <span aria-hidden="true">→</span>}
            <span>{flywheelLabels[stage]}</span>
          </Fragment>
        ))
      }
      <span aria-hidden="true">↺</span>
      <a href="/flywheel" class="link-quiet text-accent hover:text-ink"
        >The loop</a
      >
    </p>
  </section>

  <section id="work" class="mx-auto max-w-5xl px-6 pb-8">
    <div class="mb-7 flex flex-wrap items-end justify-between gap-4">
      <div>
        <p class="text-2xs uppercase tracking-[0.18em] text-accent">
          The shelf
        </p>
        <h2 class="mt-2 text-2xl text-ink">
          Sell the product. Fulfill the build.
        </h2>
      </div>
      <span class="max-w-xs text-right text-sm text-ink-faint"
        >Each card is one canonical product family with multiple buyer and
        delivery lenses.</span
      >
    </div>

    <nav
      aria-label="Catalogue categories"
      class="mb-10 flex flex-wrap gap-x-4 gap-y-2 border-y border-line py-4 text-sm text-ink-soft"
    >
      {
        groups.map((group) => (
          <a
            class="link-quiet hover:text-ink"
            href={`#${group.toLowerCase().replaceAll(" ", "-")}`}
          >
            {group}
          </a>
        ))
      }
    </nav>

    {
      apps.length === 0 ? (
        <p class="text-ink-soft">
          The first product is being prepared for the catalogue.
        </p>
      ) : (
        <div class="space-y-12">
          {groups.map((group) => {
            const groupApps = apps.filter((app) => app.data.category === group);
            if (!groupApps.length) return null;
            return (
              <section
                id={group.toLowerCase().replaceAll(" ", "-")}
                aria-labelledby={`${group}-heading`}
              >
                <div class="mb-4 flex items-baseline justify-between border-b border-line pb-3">
                  <h3 id={`${group}-heading`} class="text-lg text-ink">
                    {group}
                  </h3>
                  <span class="text-2xs uppercase tracking-wide text-ink-faint">
                    {groupApps.length} offers
                  </span>
                </div>
                <ul class="grid auto-rows-fr grid-cols-1 gap-4 md:grid-cols-2">
                  {groupApps.map((app) => (
                    <li>
                      <AppCard app={app} />
                    </li>
                  ))}
                </ul>
              </section>
            );
          })}
        </div>
      )
    }
  </section>

  <section id="about" class="mx-auto max-w-5xl px-6 pt-16 pb-20">
    <p class="text-2xs uppercase tracking-[0.18em] text-accent">
      Operating model
    </p>
    <h2 class="mt-3 max-w-2xl text-2xl text-ink">
      One catalogue. Many funnels. A separate delivery lane.
    </h2>
    <div class="mt-6 grid gap-8 text-ink-soft md:grid-cols-3">
      <div>
        <h3 class="text-base text-ink">Catalogue</h3><p class="mt-2 text-sm">
          The public source of truth for product families, audiences, packaging
          shapes, access, and proof.
        </p>
      </div>
      <div>
        <h3 class="text-base text-ink">Marketing & sales</h3><p
          class="mt-2 text-sm"
        >
          Private operators can create audience-specific copy, funnels, Meta
          campaigns, pricing, commission rules, and handoff paths from the same
          product record.
        </p>
      </div>
      <div>
        <h3 class="text-base text-ink">Fulfillment</h3><p class="mt-2 text-sm">
          A separate delivery brief turns the sold package into an
          implementation: tuning, integrations, approvals, access, QA, launch,
          and support.
        </p>
      </div>
    </div>
    <div class="mt-10 space-y-4 text-ink-soft">
      <p>
        The shelf is intentionally longer than a single flagship. Salespeople
        need a scrollable set of recognizable problems and offers, while the
        delivery team needs a stable handoff seam instead of rebuilding the
        pitch inside fulfillment. Each entry still separates maturity, access,
        proof, and its <a
          href="/flywheel"
          class="link-quiet text-ink hover:text-accent">flywheel stage</a
        > so planned inventory is never mistaken for a finished, earning service.
      </p>
      <p>
        Armalo is the thread between them: proprietary Hermes Agent tunings,
        product packaging, and implementation discipline. Public status remains
        honest: planned products are catalogue inventory, not live claims.
      </p>
    </div>
  </section>
</Base>
