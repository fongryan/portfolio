---
import Base from "../layouts/Base.astro";
---

<Base
  title="Page not found — Ryan Fong"
  description="The requested page is not part of Ryan Fong's public product catalogue."
>
  <section class="mx-auto max-w-3xl px-6 py-24">
    <p class="text-2xs font-medium uppercase tracking-[0.18em] text-accent">
      404
    </p>
    <h1 class="mt-4 text-4xl text-ink">That page is not in the catalogue.</h1>
    <p class="mt-5 max-w-xl text-lg text-ink-soft">
      The product may have moved, or the address may be incomplete.
    </p>
    <a
      href="/#work"
      class="mt-8 inline-flex rounded-md bg-ink px-4 py-2 text-sm font-medium text-paper link-quiet hover:bg-accent"
    >
      Return to the catalogue
    </a>
  </section>
</Base>
