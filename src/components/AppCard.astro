---
/*
 * AppCard — one product in the catalogue. Every entry gets an internal detail
 * page so the homepage can stay neutral while any product can later become the
 * lead. External destinations belong on the detail page.
 */
import type { CollectionEntry } from "astro:content";
import StatusBadge from "./StatusBadge.astro";

interface Props {
  app: CollectionEntry<"apps">;
}
const { app } = Astro.props;
const { name, status, category, description, year } = app.data;
const href = `/apps/${app.id}`;
const isLink = true;
const Tag = "a";
const linkProps = { href };
---

<Tag
  {...linkProps}
  class:list={[
    "group flex h-full flex-col rounded-md border border-line bg-paper p-5",
    "transition-colors duration-150 hover:border-accent focus-visible:outline-none",
  ]}
>
  <div class="flex items-start justify-between gap-3">
    <h3 class="text-lg font-semibold tracking-tight text-ink">
      {name}
    </h3>
    <StatusBadge status={status} />
  </div>

  <p class="mt-1 text-sm text-ink-soft">{description}</p>

  <div
    class="mt-auto flex flex-wrap items-center gap-x-3 gap-y-1 pt-4 text-2xs uppercase tracking-wide text-ink-faint"
  >
    <span>{category}</span>
    <span aria-hidden="true">·</span>
    <span>{year}</span>
    {isLink && (
      <span
        class="ml-auto text-accent opacity-0 transition-opacity duration-150 group-hover:opacity-100"
        aria-hidden="true"
      >
        Open →
      </span>
    )}
  </div>
</Tag>
