---
import type { CollectionEntry } from "astro:content";
import { accessLabels, flywheelLabels, proofLabels } from "../lib/apps";
import StatusBadge from "./StatusBadge.astro";

interface Props {
  app: CollectionEntry<"apps">;
  compact?: boolean;
}
const { app, compact = false } = Astro.props;
const {
  name,
  status,
  access,
  proof,
  flywheel,
  category,
  description,
  year,
  audiences,
  salesPosition,
  commercialPriority,
  buyerHypothesis,
} = app.data;
const href = `/apps/${app.id}`;
const buyerHypothesisText = buyerHypothesis?.replace(
  /^Armalo hypothesis:\s*/,
  "",
);
---

{
  compact ? (
    <a href={href} class="demand-card">
      <strong>{name}</strong>
      <span class="demand-card__description">{description}</span>
    </a>
  ) : (
    <a
      href={href}
      class:list={[
        "group flex h-full flex-col rounded-md border border-line bg-paper p-5",
        "transition-colors duration-150 hover:border-accent focus-visible:outline-none",
      ]}
    >
      <div class="flex items-start justify-between gap-3">
        <h3 class="text-lg font-semibold tracking-tight text-ink">{name}</h3>
        <StatusBadge status={status} />
      </div>

      <p class="mt-1 text-sm text-ink-soft">{description}</p>
      {commercialPriority && buyerHypothesisText && (
        <div class="mt-4 border-l border-accent pl-3">
          <p class="text-2xs uppercase tracking-wide text-accent">
            Commercial priority {String(commercialPriority).padStart(2, "0")}
          </p>
          <p class="mt-1 text-xs leading-relaxed text-ink-soft">
            Our buyer hypothesis: {buyerHypothesisText}
          </p>
        </div>
      )}
      <p class="mt-4 text-sm leading-relaxed text-ink-soft">{salesPosition}</p>

      <p class="mt-4 text-xs text-ink-faint">
        For {audiences.slice(0, 2).join(" · ")}
      </p>
      <p class="mt-3 border-t border-line pt-3 text-2xs uppercase tracking-wide text-ink-faint">
        {accessLabels[access]} · {proofLabels[proof]} ·{" "}
        {flywheelLabels[flywheel]}
      </p>

      <div class="mt-auto flex flex-wrap items-center gap-x-3 gap-y-1 pt-4 text-2xs uppercase tracking-wide text-ink-faint">
        <span>{category}</span>
        <span aria-hidden="true">·</span>
        <span>{year}</span>
        <span
          class="ml-auto text-accent opacity-0 transition-opacity duration-150 group-hover:opacity-100"
          aria-hidden="true"
        >
          Details →
        </span>
      </div>
    </a>
  )
}
