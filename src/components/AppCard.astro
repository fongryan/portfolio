---
/*
 * AppCard — one mini-app in the grid. Renders as a link to the subdomain when
 * the entry has a URL and is live/wip; planned apps are non-links with a quiet
 * affordance. Restraint over decoration: a hairline border, generous padding,
 * and one accent on hover. No shadows, no scale transform, no gradient.
 */
import type { CollectionEntry } from "astro:content";
import StatusBadge from "./StatusBadge.astro";

interface Props {
  app: CollectionEntry<"apps">;
}
const { app } = Astro.props;
const { name, url, status, category, description, year } = app.data;
const isLink = !!url && status !== "planned";
const Tag = isLink ? "a" : "div";
const linkProps = isLink
  ? { href: url, target: "_blank", rel: "noopener noreferrer" }
  : {};
---

<Tag
  {...linkProps}
  class:list={[
    "group flex h-full flex-col rounded-md border border-line bg-paper p-5",
    isLink &&
      "transition-colors duration-150 hover:border-accent focus-visible:outline-none",
    !isLink && "cursor-default opacity-90",
  ]}
>
  <div class="flex items-start justify-between gap-3">
    <h3 class="text-lg font-semibold tracking-tight text-ink">
      {name}
    </h3>
    <StatusBadge status={status} />
  </div>

  <p class="mt-1 text-sm text-ink-soft">{description}</p>

  <div
    class="mt-auto flex flex-wrap items-center gap-x-3 gap-y-1 pt-4 text-2xs uppercase tracking-wide text-ink-faint"
  >
    <span>{category}</span>
    <span aria-hidden="true">·</span>
    <span>{year}</span>
    {isLink && (
      <span
        class="ml-auto text-accent opacity-0 transition-opacity duration-150 group-hover:opacity-100"
        aria-hidden="true"
      >
        Open →
      </span>
    )}
  </div>
</Tag>
