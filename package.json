{
  "name": "portfolio",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "description": "Ryan Fong's portfolio hub \u2014 links the subdomains hosting the Armalo mini-apps.",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "doctor": "./scripts/portfolio-doctor.sh",
    "test": "node --test scripts/catalogue-contract.test.mjs scripts/portfolio-deploy-contract.test.mjs scripts/portfolio-doctor-contract.test.mjs scripts/portfolio-proof-contract.test.mjs scripts/demand-catalogue-contract.test.mjs scripts/managed-agent-infrastructure-contract.test.mjs scripts/product-atlas-contract.test.mjs scripts/marketing-content-contract.test.mjs",
    "test:deploy": "npm test",
    "test:output": "node --test scripts/site-output.test.mjs scripts/demand-catalogue-output.test.mjs scripts/managed-agent-infrastructure-output.test.mjs scripts/marketing-content-output.test.mjs",
    "budget": "node --test scripts/performance-budget.test.mjs",
    "proof": "./scripts/portfolio-proof.sh",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "format:vercel": "node scripts/check-vercel-format.mjs"
  },
  "license": "MIT",
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@tailwindcss/vite": "^4.3.2",
    "astro": "^7.0.7",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "zod": "^3.23.8",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "js-yaml": "^4.3.0",
    "prettier": "^3.9.4",
    "prettier-plugin-astro": "^0.14.1"
  }
}
